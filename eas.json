{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NODE_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://furever-1-lekw.onrender.com"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://furever-1-lekw.onrender.com"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://furever-1-lekw.onrender.com"
      }
    }
  }
}
