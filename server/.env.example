# Required for stable auth tokens
JWT_SECRET=replace-with-a-long-random-secret

# Optional SMTP (if omitted, app falls back to Ethereal in non-production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# SQLite DB file path
# Local dev default is server/furever.db. On Render use /data/furever.db
SQLITE_DB_PATH=server/furever.db

# Optional Firebase Admin service account path for FCM
# On Render this can be /etc/secrets/gsa-key.json if you upload a Secret File
FIREBASE_SERVICE_ACCOUNT_PATH=
